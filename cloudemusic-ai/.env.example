# 百炼平台 API 配置
# 请前往 https://bailian.console.aliyun.com/ 获取 API Key
BAILIAN_API_KEY=your-bailian-api-key-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_LLM_MODEL=qwen-plus
BAILIAN_EMBEDDING_MODEL=text-embedding-v3

# Spring Boot 后端地址（FastAPI 通过此地址获取歌曲数据和用户信息）
SPRING_BOOT_URL=http://localhost:8000

# FastAPI 服务端口
AI_SERVICE_PORT=8001
